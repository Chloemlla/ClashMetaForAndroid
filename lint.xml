<?xml version="1.0" encoding="UTF-8"?>
<lint>
    <!--
      Room KSP generates Database_Impl that subclasses restricted RoomOpenHelper.Delegate.
      This project adds KSP outputs to variant sourceSets for compilation, so Lint treats
      those generated files as first-party sources and reports hundreds of RestrictedApi false positives.
    -->
    <issue id="RestrictedApi">
        <ignore path="**/build/generated/**" />
        <ignore regexp=".*_Impl\.java" />
    </issue>

    <!-- Partial/community locale packs are maintained separately from CI. -->
    <issue id="MissingTranslation" severity="ignore" />
    <issue id="ExtraTranslation" severity="ignore" />

    <!-- Vector adaptive icons / launcher metadata commonly trip these on library consumers. -->
    <issue id="IconLauncherShape" severity="ignore" />
    <issue id="IconDipSize" severity="ignore" />
    <issue id="IconDuplicatesConfig" severity="ignore" />
    <issue id="IconLocation" severity="ignore" />
    <issue id="IconDensities" severity="ignore" />
    <issue id="IconMissingDensityFolder" severity="ignore" />

    <!-- Older multi-ABI packaging + Go/native artifacts produce many packaging notices. -->
    <issue id="UnusedResources" severity="ignore" />
    <issue id="VectorPath" severity="ignore" />
</lint>
