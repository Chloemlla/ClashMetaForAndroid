<?xml version="1.0" encoding="UTF-8"?>
<lint>
    <!--
      Room KSP generates Database_Impl that subclasses restricted RoomOpenHelper.Delegate.
      This project adds KSP outputs to variant sourceSets for compilation, so Lint treats
      those generated files as first-party sources and reports hundreds of RestrictedApi false positives.
    -->
    <issue id="RestrictedApi">
        <ignore path="**/build/generated/**" />
        <ignore regexp=".*_Impl\.java" />
    </issue>

    <!-- Dependency version nags are tracked via Renovate, not CI lint failures. -->
    <issue id="GradleDependency" severity="ignore" />
    <issue id="AndroidGradlePluginVersion" severity="ignore" />
    <issue id="UseTomlInstead" severity="ignore" />

    <!-- Locale packs may lag or diverge slightly from default strings. -->
    <issue id="MissingTranslation" severity="ignore" />
    <issue id="ExtraTranslation" severity="ignore" />

    <!-- Launcher/icon density noise and unused resources from multi-flavor packaging. -->
    <issue id="IconLauncherShape" severity="ignore" />
    <issue id="IconDipSize" severity="ignore" />
    <issue id="IconDuplicatesConfig" severity="ignore" />
    <issue id="IconLocation" severity="ignore" />
    <issue id="IconDensities" severity="ignore" />
    <issue id="IconMissingDensityFolder" severity="ignore" />
    <issue id="UnusedResources" severity="ignore" />
    <issue id="VectorPath" severity="ignore" />
    <issue id="VectorRaster" severity="ignore" />

    <!--
      Same-signing migration permission is intentionally shared across alpha/meta packages.
      Lint UniquePermission / ProtectedPermissions noise is not actionable here.
    -->
    <issue id="UniquePermission">
        <ignore regexp=".*MIGRATE_DATA.*" />
    </issue>

    <!--
      MigrationProvider is exported on purpose with a signature-level permission and
      an additional same-signature runtime check. Treat as intentional, not a defect.
    -->
    <issue id="ExportedContentProvider">
        <ignore path="**/service/src/main/AndroidManifest.xml" />
        <ignore regexp=".*MigrationProvider.*" />
    </issue>
</lint>