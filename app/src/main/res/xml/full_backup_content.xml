<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Only non-sensitive UI preferences are eligible for legacy Auto Backup. -->
    <include
        domain="sharedpref"
        path="." />

    <!-- Profiles contain subscription sources and ageSecretKey values. -->
    <exclude
        domain="database"
        path="." />
    <exclude
        domain="file"
        path="imported" />
    <exclude
        domain="file"
        path="pending" />
    <exclude
        domain="file"
        path="clash" />
</full-backup-content>
