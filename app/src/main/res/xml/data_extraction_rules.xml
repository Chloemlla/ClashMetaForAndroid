<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!--
      Explicitly include only shared preferences. Profile databases, imported/
      pending config files, and Clash state stay out of cloud backup and
      device-to-device transfer without redundant excludes.
    -->
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
